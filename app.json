{
  "expo": {
    "name": "Period Tracker",
    "slug": "period-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "periodtracker",
    "userInterfaceStyle": "automatic",
    "owner": "periodtracker",
    "description": "An AI-powered menstrual health companion that combines cycle tracking, wellness insights, mood prediction, and beautifully crafted interactions.",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B9D"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTabletMode": true,
      "requireFullScreen": false,
      "bundleIdentifier": "com.periodtracker.app",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#FBF7F5"
      },
      "privacyManifests": [
        {
          "NSPrivacyTracking": false,
          "NSPrivacyTrackingDomains": []
        }
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FBF7F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.periodtracker.app",
      "permissions": [],
      "softwareKeyboardLayoutMode": "pan",
      "blockedPermissions": [
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF7F5",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "minimumDeploymentTarget": "14.0"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "period-tracker-app"
      }
    }
  }
}